# URL for the backend API.
# Local development: http://localhost:8000
# Production (Render): https://your-backend.onrender.com
VITE_API_URL=https://your-api-domain.com

# Firebase Client Configuration 
# (These are public-facing keys safe to expose in the frontend)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=app-oficios-ffc35.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=app-oficios-ffc35
VITE_FIREBASE_STORAGE_BUCKET=app-oficios-ffc35.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
